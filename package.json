{
  "name": "dockyard-mods-tooling",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-types": "bun run scripts/generate-types.ts",
    "format:registry": "bun run src/cli/format-registry.ts ./registry.json",
    "validate:registry:schema": "bun run src/cli/validate-registry-schema.ts ./registry.json https://raw.githubusercontent.com/DockyardMods/the-dockyard/main/schemas/registry.schema.json",
    "validate:registry:content": "bun run src/cli/validate-registry-content.ts ./registry.json",
    "validate:registry": "bun run validate:registry:schema && bun run validate:registry:content",
    "validate:manifest:schema": "bun run src/cli/validate-manifest-schema.ts ./manifest.yml",
    "validate:manifest:content": "bun run src/cli/validate-manifest-content.ts ./manifest.yml",
    "validate:manifest": "bun run validate:manifest:schema && bun run validate:manifest:content"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.5",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.8.2",
    "temporal-polyfill": "^0.3.2",
    "try": "^1.0.3"
  }
}
